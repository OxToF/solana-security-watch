# Environment / secrets — NEVER commit
.env
.env.*
!.env.example
*.env
.envrc

# API keys, RPC endpoints, tokens
*secret*
*credentials*
*.pem
*.key
*-keypair.json
id.json
wallet*.json
.config/solana/

# Anchor / Solana build artifacts
target/
.anchor/
test-ledger/

# ...but the PoC's compiled program + IDL are committed on purpose so the suite
# runs standalone (`yarn && yarn test`, no `anchor build` needed). The program
# keypair stays ignored (OPSEC rule above) — it isn't needed to run the tests.
!poc/*/target/
poc/*/target/*
!poc/*/target/deploy/
poc/*/target/deploy/*
!poc/*/target/deploy/*.so
!poc/*/target/idl/

# Rust
Cargo.lock.bak
**/*.rs.bk

# Node / tooling
node_modules/
dist/
.cache/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
